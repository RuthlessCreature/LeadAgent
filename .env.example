# LeadAgent 配置文件
# 复制此文件为 .env 并填入你的配置

# LLM 配置 (DeepSeek/OpenAI/Claude/Minimax)
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-flash-thinking
DEEPSEEK_REPORT_MODEL=deepseek-v4-pro
DEEPSEEK_REPORT_REASONING_MODEL=deepseek-v4-pro-thinking
DEEPSEEK_TIMEOUT_SECONDS=90
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_claude_key
MINIMAX_API_KEY=your_minimax_key
DEFAULT_LLM=deepseek

# 搜索配置
SEARCH_TIMEOUT=10
SEARCH_QUERY_VARIANTS=3
STEALTH_MODE=true

# LinkedIn Selenium scraping (public profile pages)
LINKEDIN_BROWSER=edge
LINKEDIN_HEADLESS=false
LINKEDIN_MAX_QUERIES=6
LINKEDIN_MAX_PROFILES_PER_QUERY=8
LINKEDIN_MAX_PAGES_PER_QUERY=3
LINKEDIN_SCROLL_ROUNDS=3
LINKEDIN_DELAY_MIN=1.2
LINKEDIN_DELAY_MAX=2.9
LINKEDIN_WAIT_TIMEOUT=18
LINKEDIN_PAGE_LOAD_TIMEOUT=40
LINKEDIN_MANUAL_LOGIN_WAIT_SECONDS=90
# Optional: persistent browser data dir to reuse logged-in session
# LINKEDIN_USER_DATA_DIR=C:\\path\\to\\browser-user-data
