# LeadAgent 配置文件
# 复制此文件为 .env 并填入你的配置

# LLM 配置 (选择其中一个或多个)
# DeepSeek
DEEPSEEK_API_KEY=sk-5d8d640d3e3b4eacb71402927faa9268
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI
# OPENAI_API_KEY=your_openai_key

# Anthropic (Claude)
# ANTHROPIC_API_KEY=your_claude_key

# MiniMax
# MINIMAX_API_KEY=your_minimax_key

# 默认使用哪个 LLM (deepseek/openai/claude/minimax)
DEFAULT_LLM=deepseek

# 搜索配置
SEARCH_TIMEOUT=10
SEARCH_QUERY_VARIANTS=3

# 反检测配置
STEALTH_MODE=true

# LinkedIn Selenium session reuse
LINKEDIN_USER_DATA_DIR=E:\\GitHub\\LeadAgent\\data\\linkedin_edge_profile_v3
LINKEDIN_MAX_PAGES_PER_QUERY=3
